\">0</field></shadow><block type=\\\"device_random\\\" id=\\\"Lym@ug@dNN:6^1?[j_E7\\\"><value name=\\\"min\\\"><shadow type=\\\"math_number\\\" id=\\\"w6/;3G;J^?i4_X@U=_;5\\\"><field name=\\\"NUM\\\">10</field></shadow></value><value name=\\\"limit\\\"><shadow type=\\\"math_number\\\" id=\\\"?Nn8WRXk6;@[Wb9cvLP!\\\"><field name=\\\"NUM\\\">150</field></shadow></value></block></value><value name=\\\"y\\\"><shadow type=\\\"positionPicker\\\" id=\\\"Rz(,-VcXM-)?LOFgQt}P\\\"><field name=\\\"index\\\">0</field></shadow><block type=\\\"device_random\\\" id=\\\"}$YE2?DJ%lQ}M2/^0Q*M\\\"><value name=\\\"min\\\"><shadow type=\\\"math_number\\\" id=\\\"^:99MxoMvPo9sG!_3api\\\"><field name=\\\"NUM\\\">10</field></shadow></value><value name=\\\"limit\\\"><shadow type=\\\"math_number\\\" id=\\\"6k$}S:qxPV}e_)dccNm`\\\"><field name=\\\"NUM\\\">110</field></shadow></value></block></value></block></statement></block></next></block></next></block></statement><next><block type=\\\"variables_set\\\" id=\\\"H|?G)}KjeIZc)B)tD0Pp\\\"><field name=\\\"VAR\\\" id=\\\"`96H5V$zhzYRCb?0Z]TZ\\\">keyVase</field><value name=\\\"VALUE\\\"><shadow type=\\\"math_number\\\" id=\\\"oweCj$2)#tpnL2D/;=Q~\\\"><field name=\\\"NUM\\\">0</field></shadow><block type=\\\"lists_index_get\\\" id=\\\"spCnGZU8_ArfTZ`#,P4F\\\"><value name=\\\"LIST\\\"><block type=\\\"variables_get\\\" id=\\\"]k8d*TLX7/KC|c_cC.X_\\\"><field name=\\\"VAR\\\" id=\\\"-CiB{FLs+QCWjr_!^UY-\\\">vases</field></block></value><value name=\\\"INDEX\\\"><shadow type=\\\"math_number\\\" id=\\\"9qzC|Jo*N@O8KrTn/gCO\\\"><field name=\\\"NUM\\\">0</field></shadow><block type=\\\"device_random\\\" id=\\\"4W7Y69%r4Xvu{h81awza\\\"><value name=\\\"min\\\"><shadow type=\\\"math_number\\\" id=\\\"t0[yQ4[(5A.D$T);p9nh\\\"><field name=\\\"NUM\\\">0</field></shadow></value><value name=\\\"limit\\\"><block type=\\\"math_arithmetic\\\" id=\\\"aGoeqynImV;0{!#=9^-.\\\"><field name=\\\"OP\\\">MINUS</field><value name=\\\"A\\\"><shadow type=\\\"math_number\\\" id