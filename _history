st, tile2)\\n}\\n// =====================\\n// WIN CONDITION\\n// =====================\\nsprites.onOverlap(SpriteKind.Player, SpriteKind.Projectile, function (player2, chest) {\\n    if (keyFound) {\\n        game.showLongText(\\\"Level Complete!\\\", DialogLayout.Center)\\n        game.over(true)\\n    }\\n})\\nlet tile2: tiles.Location = null\\nlet locations2: tiles.Location[] = []\\nlet chest: Sprite = null\\nlet keyFound = false\\nlet roll = 0\\nlet vase: Sprite = null\\nlet dy = 0\\nlet dx = 0\\nlet tile: tiles.Location = null\\nlet attempts = 0\\nlet placed = 0\\nlet locations: tiles.Location[] = []\\nlet heroTile: tiles.Location = null\\nlet health = 0\\nhealth = 3\\n// =====================\\n// TILEMAP\\n// =====================\\ntiles.setTilemap(tilemap`F1`)\\n// =====================\\n// PLAYER (CENTER SPAWN)\\n// =====================\\nlet hero = sprites.create(assets.image`hero`, SpriteKind.Player)\\nlet allTiles = tiles.getTilesByType(assets.tile`baseTransparency16`)\\nlet centerIndex = Math.floor(allTiles.length / 2)\\nheroTile = allTiles[centerIndex]\\ntiles.placeOnTile(hero, heroTile)\\n// camera follows hero\\nscene.cameraFollowSprite(hero)\\ncontroller.moveSprite(hero)\\ninfo.setScore(health)\\n// =====================\\n// START\\n// =====================\\nspawnVases()\\n\",\n  \"pxt.json\": \"{\\n    \\\"name\\\": \\\"Team Dorris Dann: Game Name Here 5/13/2026 5:25 PM\\\",\\n    \\\"description\\\": \\\"DDKC Game Dev\\\",\\n    \\\"dependencies\\\": {\\n        \\\"device\\\": \\\"*\\\"\\n    },\\n    \\\"files\\\": [\\n        \\\"main.blocks\\\",\\n        \\\"main.ts\\\",\\n        \\\"README.md\\\",\\n        \\\"assets.json\\\",\\n        \\\"images.g.jres\\\",\\n        \\\"images.g.ts\\\",\\n        \\\"tilemap.g.jres\\\",\\n        \\\"tilemap.g.ts\\\"\\n    ],\\n    \\\"testFiles\\\": [\\n        \\\"test.ts\\\"\\n    ],\\n    \\\"targetVersions\\\": {\\n        \\\"target\\\": \\\"4.0.14\\\",\\n        \\\"targetId\\\": \\\"arcade